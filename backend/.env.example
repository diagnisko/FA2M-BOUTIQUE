# ─── Serveur ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Sécurité (CHANGEZ EN PRODUCTION !) ────────────────────────
# Générer avec: openssl rand -base64 32
JWT_SECRET=remplacez_par_une_chaine_aleatoire_tres_longue_min_32_chars
JWT_EXPIRES_IN=24h

# ─── Base de données ────────────────────────────────────────────
DB_PATH=./data/fa2m.db

# ─── Compte Administrateur (CHANGEZ EN PRODUCTION !) ───────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changez_ce_mot_de_passe_securise

# ─── CORS — Origines autorisées (séparées par virgule) ─────────
FRONTEND_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000

# ─── URLs de l'application ──────────────────────────────────────
APP_URL=http://localhost:3000
API_URL=http://localhost:3000

# ═══════════════════════════════════════════════════════════════════════════════
# 💳 CONFIGURATION PAIEMENTS - Voir PAYMENT_SETUP_GUIDE.md
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Wave (https://www.wave.com/developers) ─────────────────────
# 1. Créer compte marchand: https://www.wave.com/
# 2. Aller dans Settings → API Keys
# 3. Copier le Bearer Token
# 4. Copier le Webhook Secret
WAVE_API_KEY=sk_live_votre_cle_api_wave_ici
WAVE_WEBHOOK_SECRET=wh_secret_votre_webhook_secret_ici

# ─── Orange Money (https://developer.orange.com) ────────────────
# 1. S'enregistrer: https://developer.orange.com
# 2. Créer une application
# 3. Copier Client ID et Client Secret
# 4. Ajouter Merchant Key (dans settings marchands)
OM_CLIENT_ID=votre_client_id_orange_ici
OM_CLIENT_SECRET=votre_client_secret_orange_ici
OM_MERCHANT_KEY=votre_merchant_key_orange_ici
OM_COUNTRY=sn

# ═══════════════════════════════════════════════════════════════════════════════

# ─── Configuration Boutique ─────────────────────────────────────
SHOP_PHONE=221781332323
SHOP_NAME=FA2M
